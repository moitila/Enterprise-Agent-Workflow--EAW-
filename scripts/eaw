#!/usr/bin/env bash
set -euo pipefail

# Error handling: trap ERR to show file, function, line, command
set -E
on_err() {
	local exit_code=$?
	local cmd="${BASH_COMMAND}"
	local src="${BASH_SOURCE[1]:-${BASH_SOURCE[0]}}"
	local fn="${FUNCNAME[1]:-main}"
	local line="${BASH_LINENO[0]:-0}"

	printf "EAW_ERROR: exit=%d at %s:%s:%d cmd: %s\n" \
		"$exit_code" "${src##*/}" "$fn" "$line" "$cmd" >&2

	exit "$exit_code"
}
trap on_err ERR

# Simple CLI for EAW
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
LIB="$SCRIPT_DIR/lib.sh"

if [[ -f "$LIB" ]]; then
	# shellcheck disable=SC1090
	source "$LIB"
else
	echo "Missing library $LIB" >&2
	exit 1
fi

resolve_workdirs "$ROOT_DIR"

CONFIG_DIR="$EAW_CONFIG_DIR"
REPOS_CONF="$CONFIG_DIR/repos.conf"
SEARCH_CONF="$CONFIG_DIR/search.conf"
EAW_CONF="$CONFIG_DIR/eaw.conf"
REQUIRED_CONFIG_VERSION=1

# shellcheck disable=SC1091
source "$SCRIPT_DIR/eaw_core.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_init.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_feature.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_bug.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_spike.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/eaw_commands.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_validate.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_doctor.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_implement.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_analyze.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_ingest.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_intake.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_validate_prompt.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_apply_prompt.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_propose_prompt.sh"

main() {
	if [[ $# -lt 1 ]]; then
		usage
		exit 1
	fi
	case "$1" in
	init)
		cmd_init "${@:2}"
		;;
	feature)
		if [[ $# -lt 3 ]]; then
			echo "Missing args" >&2
			usage
			exit 1
		fi
		validate_runtime_workdir
		cmd_feature "$2" "$3"
		;;
	bug)
		if [[ $# -lt 3 ]]; then
			echo "Missing args" >&2
			usage
			exit 1
		fi
		validate_runtime_workdir
		cmd_bug "$2" "$3"
		;;
	spike)
		if [[ $# -lt 3 ]]; then
			echo "Missing args" >&2
			usage
			exit 1
		fi
		validate_runtime_workdir
		cmd_spike "$2" "$3"
		;;
	analyze)
		if [[ $# -lt 2 ]]; then
			echo "Missing args" >&2
			usage
			exit 1
		fi
		validate_runtime_workdir
		cmd_analyze "$2"
		;;
	intake)
		validate_runtime_workdir
		if [[ "$#" -eq 2 ]]; then
			cmd_intake "$2"
		elif [[ "$#" -eq 3 && "$3" == --round=* ]]; then
			cmd_intake "$2" "$3"
		else
			echo "ERROR: invalid intake arguments" >&2
			echo "usage: eaw intake <CARD> [--round=N]" >&2
			exit 1
		fi
		;;
	ingest)
		if [[ $# -lt 3 ]]; then
			echo "Missing args" >&2
			usage
			exit 1
		fi
		validate_runtime_workdir
		cmd_ingest "$2" "$3"
		;;
	implement)
		if [[ $# -ne 2 ]]; then
			die "usage: eaw implement <CARD>"
		fi
		validate_runtime_workdir
		cmd_implement "$2"
		;;
	validate-prompt)
		if [[ $# -ne 4 ]]; then
			echo "usage: eaw validate-prompt <TRACK> <PHASE> <CANDIDATE>" >&2
			exit 2
		fi
		validate_runtime_workdir
		cmd_validate_prompt "$2" "$3" "$4"
		;;
	propose-prompt)
		if [[ $# -ne 6 ]]; then
			echo "usage: eaw propose-prompt <CARD> <TRACK> <PHASE> <BASE_CANDIDATE> <NEW_CANDIDATE>" >&2
			exit 2
		fi
		validate_runtime_workdir
		cmd_propose_prompt "$2" "$3" "$4" "$5" "$6"
		;;
	apply-prompt)
		if [[ $# -ne 4 ]]; then
			echo "usage: eaw apply-prompt <TRACK> <PHASE> <CANDIDATE>" >&2
			exit 2
		fi
		validate_runtime_workdir
		cmd_apply_prompt "$2" "$3" "$4"
		;;
	validate)
		if cmd_validate; then
			exit 0
		else
			exit $?
		fi
		;;
	doctor)
		cmd_doctor
		;;
	--help | -h)
		usage
		exit 0
		;;
	*)
		usage
		exit 1
		;;
	esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
	main "$@"
fi
