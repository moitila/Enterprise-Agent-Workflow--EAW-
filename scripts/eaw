#!/usr/bin/env bash
set -euo pipefail

# Error handling: trap ERR to show file, function, line, command
set -E
on_err() {
	local exit_code=$?
	local cmd="${BASH_COMMAND}"
	local src="${BASH_SOURCE[1]:-${BASH_SOURCE[0]}}"
	local fn="${FUNCNAME[1]:-main}"
	local line="${BASH_LINENO[0]:-0}"

	printf "EAW_ERROR: exit=%d at %s:%s:%d cmd: %s\n" \
		"$exit_code" "${src##*/}" "$fn" "$line" "$cmd" >&2

	exit "$exit_code"
}
trap on_err ERR

# Simple CLI for EAW
resolve_script_path() {
	local source_path="$1"
	while [[ -L "$source_path" ]]; do
		local source_dir
		source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
		source_path="$(readlink "$source_path")"
		[[ "$source_path" == /* ]] || source_path="$source_dir/$source_path"
	done
	cd -P "$(dirname "$source_path")" && pwd
}

SCRIPT_DIR="$(resolve_script_path "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
LIB="$SCRIPT_DIR/lib.sh"

if [[ -f "$LIB" ]]; then
	# shellcheck disable=SC1090
	source "$LIB"
else
	echo "Missing library $LIB" >&2
	exit 1
fi

resolve_workdirs "$ROOT_DIR"

CONFIG_DIR="$EAW_CONFIG_DIR"
REPOS_CONF="$CONFIG_DIR/repos.conf"
SEARCH_CONF="$CONFIG_DIR/search.conf"
EAW_CONF="$CONFIG_DIR/eaw.conf"
REQUIRED_CONFIG_VERSION=1

# shellcheck disable=SC1091
source "$SCRIPT_DIR/eaw_core.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_init.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/eaw_commands.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/workflow_validation.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_validate.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_doctor.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_doctor_hardening.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_implement.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_analyze.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_intake.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_validate_prompt.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_apply_prompt.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_suggest_prompt.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_propose_prompt.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/commands/cmd_test_suites.sh"

main() {
	if [[ $# -lt 1 ]]; then
		usage
		exit 1
	fi

	# Normalize help for subcommands before positional routing.
	case "$1:${2:-}" in
	analyze:--help | analyze:-h | intake:--help | intake:-h | implement:--help | implement:-h)
		usage
		exit 0
		;;
	esac

	case "$1" in
	init)
		cmd_init "${@:2}"
		;;
	card)
		validate_runtime_workdir
		cmd_card_cli "${@:2}"
		;;
	analyze)
		if [[ $# -lt 2 ]]; then
			echo "Missing args" >&2
			usage
			exit 1
		fi
		validate_runtime_workdir
		cmd_analyze "$2"
		;;
	intake)
		validate_runtime_workdir
		if [[ "$#" -eq 2 ]]; then
			cmd_intake "$2"
		elif [[ "$#" -eq 3 && "$3" == --round=* ]]; then
			cmd_intake "$2" "$3"
		else
			echo "ERROR: invalid intake arguments" >&2
			echo "usage: eaw intake <CARD> [--round=N]" >&2
			exit 1
		fi
		;;
	implement)
		if [[ $# -ne 2 ]]; then
			die "usage: eaw implement <CARD>"
		fi
		validate_runtime_workdir
		cmd_implement "$2"
		;;
	tracks)
		if [[ "${2:-}" == "install" ]]; then
			if [[ $# -ne 2 ]]; then
				die "usage: eaw tracks install"
			fi
			validate_runtime_workdir
			cmd_tracks_install
		else
			if [[ $# -ne 1 ]]; then
				die "usage: eaw tracks"
			fi
			cmd_tracks
		fi
		;;
	run)
		if [[ $# -ne 2 ]]; then
			die "usage: eaw run <CARD>"
		fi
		validate_runtime_workdir
		cmd_run "$2"
		;;
	next)
		if [[ $# -ne 2 ]]; then
			die "usage: eaw next <CARD>"
		fi
		validate_runtime_workdir
		cmd_next "$2"
		;;
	complete)
		if [[ $# -ne 2 ]]; then
			die "usage: eaw complete <CARD>"
		fi
		validate_runtime_workdir
		cmd_complete "$2"
		;;
	smoke)
		validate_runtime_workdir
		cmd_smoke "${@:2}"
		;;
	test)
		validate_runtime_workdir
		cmd_test "${@:2}"
		;;
	prompt)
		if [[ "$#" -eq 2 && "$2" == "validate" ]]; then
			validate_runtime_workdir
			cmd_validate_prompt
		else
			echo "usage: eaw prompt validate" >&2
			exit 2
		fi
		;;
	validate-prompt)
		if [[ $# -ne 4 ]]; then
			echo "usage: eaw validate-prompt <TRACK> <PHASE> <CANDIDATE>" >&2
			exit 2
		fi
		validate_runtime_workdir
		cmd_validate_prompt "$2" "$3" "$4"
		;;
	suggest-prompt)
		validate_runtime_workdir
		cmd_suggest_prompt "${@:2}"
		;;
	propose-prompt)
		if [[ $# -ne 6 ]]; then
			echo "usage: eaw propose-prompt <CARD> <TRACK> <PHASE> <BASE_CANDIDATE> <NEW_CANDIDATE>" >&2
			exit 2
		fi
		validate_runtime_workdir
		cmd_propose_prompt "$2" "$3" "$4" "$5" "$6"
		;;
	apply-prompt)
		if [[ $# -ne 4 ]]; then
			echo "usage: eaw apply-prompt <TRACK> <PHASE> <CANDIDATE>" >&2
			exit 2
		fi
		validate_runtime_workdir
		cmd_apply_prompt "$2" "$3" "$4"
		;;
	validate)
		if [[ "$#" -ge 2 && "$2" == "workflow" ]]; then
			validate_runtime_workdir
			if cmd_validate_workflow "${@:3}"; then
				exit 0
			else
				exit $?
			fi
		fi
		if cmd_validate; then
			exit 0
		else
			exit $?
		fi
		;;
	doctor)
		cmd_doctor
		;;
	doctor-hardening)
		cmd_doctor_hardening
		;;
	--help | -h)
		usage
		exit 0
		;;
	*)
		usage
		exit 1
		;;
	esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
	main "$@"
fi
